# Default OpenAI-protocol-compatible extraction route
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Independent embedding route
EMBEDDING_MODEL=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

# Optional accounting rates. When omitted, cost-report.json is marked unpriced.
HYPER_EXTRACT_INPUT_COST_PER_MILLION=
HYPER_EXTRACT_OUTPUT_COST_PER_MILLION=
HYPER_EXTRACT_COST_CURRENCY=CNY

# Anthropic / Claude API Key (optional)
ANTHROPIC_API_KEY=
