# OpenAI API Key (Required for OpenAI-compatible providers and embeddings)
OPENAI_API_KEY=sk-your-api-key-here

# Base URL (Optional, configure when using proxy)
OPENAI_BASE_URL=https://api.openai.com/v1

# Named MiniMax route for course extraction. Kept compatible with existing
# MIMIMAX_* profile names; secrets are read only by the Worker.
MIMIMAX_MODEL=MiniMax-M2.7-highspeed
MIMIMAX_BASE_URL=https://api.minimaxi.com/v1
MIMIMAX_API_KEY=

# Independent embedding route (used for semantic dedup/global candidates).
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=

# Optional accounting rates. When omitted, cost-report.json is marked unpriced.
HYPER_EXTRACT_INPUT_COST_PER_MILLION=
HYPER_EXTRACT_OUTPUT_COST_PER_MILLION=
HYPER_EXTRACT_COST_CURRENCY=CNY

# Anthropic / Claude API Key (Optional, required when using the anthropic provider)
# CLAUDE_API_KEY is also accepted as an alias.
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
