# Hyper-Extract service operator configuration.
#
# Copy this file to `docker/.env` and fill in real values before bringing the
# stack up. `docker/.env` is the single operator file consumed by the Worker
# container via `env_file`; it also provides the interpolation variables for
# `docker compose`. Never commit the real `docker/.env`.
#
# Model provider secrets below are loaded only by the Worker. Compose exposes
# model names and base URLs, but never these keys, to the API so both processes
# can compute the same secret-free Profile fingerprint.

# Required: PostgreSQL superuser password. The stack refuses to start without it.
POSTGRES_PASSWORD=change-me-to-a-strong-secret

# Optional: stable external name for the shared /exchange volume.
# Callers that mount the same named volume use this name. Defaults to
# `hyper-extract-exchange` when unset.
EXCHANGE_VOLUME_NAME=hyper-extract-exchange

# Optional: stable external name for the service-api network. External callers
# attach to this network to reach the API. Defaults to `hyper-extract-api`.
API_NETWORK_NAME=hyper-extract-api

# Optional: host port bound to the API in the development override only.
# The base compose file never publishes a port.
HE_API_PORT=8000

# Optional: target platform for built images (e.g. linux/amd64, linux/arm64).
PLATFORM=linux/amd64

# Optional: image tag override for pre-built images. When unset the compose
# file builds from `docker/service.Dockerfile`.
HE_IMAGE=hyper-extract-service:dev

# Optional: path (relative to docker/) to the Model Profile TOML mounted into
# both the API and Worker containers at /run/config/model-profiles.toml.
MODEL_PROFILES_FILE=./model-profiles.example.toml

# Default OpenAI-compatible route (optional when using a named TOML Profile).
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Independent embedding route used by the default Profile.
EMBEDDING_MODEL=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

# Credentials referenced by model-profiles.example.toml.
MINIMAX_API_KEY=
